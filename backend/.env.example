# Variáveis de ambiente do backend
PORT=3000
NODE_ENV=development

# Chave secreta para JWT (altere em produção)
JWT_SECRET=hotel_erp_secret_key_change_in_production

# Configuração do banco de dados
DB_FILENAME=./src/database/hotel.sqlite3

# Defina como "true" para desabilitar verificação de token (APENAS para testes)
# SKIP_AUTH=true
