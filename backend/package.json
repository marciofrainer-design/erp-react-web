{
  "name": "hotel-erp-backend",
  "version": "1.0.0",
  "description": "Backend GraphQL para o sistema ERP Hotel",
  "private": true,
  "scripts": {
    "dev": "ts-node-dev --respawn --transpile-only src/server.ts",
    "build": "tsc",
    "start": "node dist/server.js",
    "migrate": "knex --knexfile knexfile.ts migrate:latest",
    "migrate:rollback": "knex --knexfile knexfile.ts migrate:rollback",
    "seed": "knex --knexfile knexfile.ts seed:run",
    "setup": "npm run migrate && npm run seed"
  },
  "dependencies": {
    "@apollo/server": "^5.5.0",
    "bcrypt": "^6.0.0",
    "better-sqlite3": "^11.10.0",
    "dotenv": "^16.5.0",
    "graphql": "^16.11.0",
    "jsonwebtoken": "^9.0.2",
    "knex": "^3.1.0"
  },
  "devDependencies": {
    "@types/bcrypt": "^5.0.2",
    "@types/better-sqlite3": "^7.6.13",
    "@types/jsonwebtoken": "^9.0.9",
    "@types/node": "^22.15.17",
    "ts-node": "^10.9.2",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.8.3"
  }
}
